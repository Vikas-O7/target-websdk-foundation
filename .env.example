# ─── Required: Adobe OAuth Server-to-Server credentials ────────────
# Create at https://developer.adobe.com/console
# Add these API products to the project:
#   • Adobe Experience Platform API
#   • Experience Platform Launch API (Reactor / Tags)
# Then assign the credential's technical account to these Admin Console
# product profiles:
#   • Adobe Experience Platform Data Collection — Launch admin / Tags admin
#   • Adobe Experience Platform Data Collection — Data Collection admin
ADOBE_CLIENT_ID=your_client_id_here
ADOBE_CLIENT_SECRET=your_client_secret_here

# Adobe Organization ID — must end with @AdobeOrg
ADOBE_ORG_ID=XXXXXXXXXXXXXXXXXXXXXXXX@AdobeOrg

# IMS scopes — these defaults cover Reactor (Tags) + AEP read/write
# operations needed by this MCP. Adjust only if your Dev Console
# integration uses different scope literals.
ADOBE_SCOPES=openid,AdobeID,read_organizations,additional_info.projectedProductContext,additional_info.roles

# ─── Optional: AEP sandbox to target ───────────────────────────────
# Defaults to "prod". Override if your datastreams live in a non-prod
# sandbox.
ADOBE_SANDBOX_NAME=prod
